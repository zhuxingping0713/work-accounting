<div class="page">
  <h2>⚙️ 设置</h2>

  <div class="settings-section">
    <h3>📝 修改用户名</h3>
    <form id="userForm" onsubmit="changeUser(event)">
      <label>新用户名:</label>
      <input name="newUsername" placeholder="输入新用户名" required minlength="2">
      <label>输入密码确认:</label>
      <input name="password" type="password" required>
      <button type="submit">修改用户名</button>
    </form>
    <div id="userMsg"></div>
  </div>

  <div class="settings-section">
    <h3>👤 修改昵称</h3>
    <form id="nameForm" onsubmit="changeName(event)">
      <label>显示昵称:</label>
      <input name="displayName" value="<%= user.displayName || user.username %>" required>
      <button type="submit">保存昵称</button>
    </form>
    <div id="nameMsg"></div>
  </div>

  <div class="settings-section">
    <h3>🔐 修改密码</h3>
    <form id="changePwdForm" onsubmit="changePwd(event)">
      <label>原密码:</label><input name="oldPwd" type="password" required>
      <label>新密码:</label><input name="newPwd" type="password" required minlength="3">
      <button type="submit">修改密码</button>
    </form>
    <div id="pwdMsg"></div>
  </div>

  <div class="settings-section">
    <h3>📋 当前账户</h3>
    <p>用户名: <strong id="curUser"><%= user.username %></strong> | 角色: <strong><%= user.role==='admin'?'管理员':'普通用户' %></strong></p>
  </div>

  <div class="settings-section">
    <h3>📊 使用说明</h3>
    <ul>
      <li><strong>账单</strong>：记录日常收入和支出</li>
      <li><strong>工资</strong>：打卡出勤，日工资 ¥240/天，支持预支</li>
      <li><strong>水电</strong>：按月记录水电气网房租</li>
      <li><strong>雇主</strong>：管理打工平台和雇主信息</li>
      <li><strong>分类</strong>：自定义收入和支出类别</li>
    </ul>
  </div>
</div>

<script>
const basePath = '<%= basePath %>';

async function changeUser(e){
  e.preventDefault();
  const r = await fetch(basePath+'/api/auth/change-username',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:e.target.newUsername.value,password:e.target.password.value})});
  const data = await r.json();
  if(data.ok){ document.getElementById('curUser').textContent = data.username||e.target.newUsername.value; document.getElementById('nameForm').displayName.value = e.target.newUsername.value; }
  document.getElementById('userMsg').textContent = data.ok?'✅ 修改成功':'❌ '+data.msg;
}

async function changeName(e){
  e.preventDefault();
  const r = await fetch(basePath+'/api/auth/change-name',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({displayName:e.target.displayName.value})});
  const data = await r.json();
  document.getElementById('nameMsg').textContent = data.ok?'✅ 修改成功':'❌ '+data.msg;
  if(data.ok) setTimeout(()=>location.reload(),500);
}

async function changePwd(e){
  e.preventDefault();
  const r = await fetch(basePath+'/api/auth/change-pwd',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({oldPwd:e.target.oldPwd.value,newPwd:e.target.newPwd.value})});
  const data = await r.json();
  document.getElementById('pwdMsg').textContent = data.ok?'✅ 修改成功':'❌ '+data.msg;
}
</script>
